def mongoagg():
            agg1=int(input("enter 1 to perform group action \n 3 to back to mongo action"))
            if agg1==1:
                
                agt1=int(input("enter 1 to group based on city \n  enter 2 to group based on name \n 3 to group based on total amount "))
                if agt1==1:
                    
                    adrs1=input("enter city on basis which you want to make group ")
                    
                    result7=collection.aggregate([{"$match": {"city": adrs1}},{"$group": {"_id": "$name", "count": {"$sum": 1}}}])
                    for document4 in result7:
                        print(f"Name: {document4['_id']}")
                    mongoagg()
                elif agt1==2:
                    nm1=input("enter name on basis which you want to make group ")
                    
                    result7=collection.aggregate([{"$match": {"name": nm1}},{"$group": {"_id": "$name", "count": {"$sum": 1}}}])
                    for document4 in result7:
                        
                        print(f"Name: {document4['_id']}")
                    mongoagg()
                elif agt1==3:
                    tamnt=int(input("enter the total_amount on basis of which you want to make group"))
                    
                    result7=collection.aggregate([{"$match": {"total_amount": tamnt}},{"$group": {"_id": "$name", "count": {"$sum": 1}}}])
                    for document4 in result7:
                        print(f"Name: {document4['_id']}")
                    mongoagg()
                    
            elif agg1==3:
                print("going back to mongo action")
                mongoaction()
def mongogtandlt():
            
            mngv=int(input("enter 1 for greater than action  \n enter 2 for less than \n enter 3 for custom greater than and less than \n enter 4 for max and min amount  \n enter 5 to get to mongoaction "))
            
            if mngv==1:
                
                gt1=int(input("enter the value you want output to be greater than from total amount"))
                fltr_doc = collection.find({"total_amount": {"$gt": gt1}}, {"name": 1, "total_amount": 1, "_id": 0})
                for document2 in fltr_doc:
                    print(f"Name: {document2['name']}, Total Amount: {document2['total_amount']}")
                mongogtandlt()
                
            elif mngv==2:
                lt1=int(input("enter the value you want output to be less than from total amount"))
                fltr_doc = collection.find({"total_amount": {"$lt": lt1}}, {"name": 1, "total_amount": 1, "_id": 0})
                for document2 in fltr_doc:
                    print(f"Name: {document2['name']}, Total Amount: {document2['total_amount']}")
                mongogtandlt()
                        
            elif mngv==3:
                gt2=int(input("enter the value you want output to be greater than from total amount"))
                lt2=int(input("enter the value you want output to be less than from total amount"))
                fltr_doc = collection.find({"total_amount": {"$gt": gt2, "$lt": lt2}}, {"name": 1, "total_amount": 1, "_id": 0})
                for document2 in fltr_doc:
                    print(f"Name: {document2['name']}, Total Amount: {document2['total_amount']}")
                mongogtandlt()
                    
            elif mngv==4:
                mgv2=int(input("enter 1 for max from total amount \n enter 2 for min total amount"))
                if mgv2==1:
                    max_documents = collection.find().sort("total_amount", -1).limit(1)
                    for document3 in max_documents:
                        print(f"Name: {document3['name']}, Price: {document3['total_amount']}, Order: {document3['orders']}, city: {document3['city']}")
                    mongogtandlt()
                elif mgv2==2:
                    min_documents = collection.find().sort("total_amount", 1).limit(1)
                    for document3 in min_documents:
                        print(f"Name: {document3['name']}, Price: {document3['total_amount']}, Order: {document3['orders']}, city: {document3['city']}")
                    mongogtandlt()
                    
            elif mngv==5:
                
                print("monving out mongo greater than less than")
                mongoaction()
